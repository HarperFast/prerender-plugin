{
	"compilerOptions": {
		"target": "ES2020",
		// Specify ECMAScript target version
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		// ES2022 for Error `cause`; DOM for in-page evaluate() code
		"module": "ES2022",
		// Specify module code generation
		"strict": true,
		// Enable all strict type-checking options
		"esModuleInterop": true,
		// Enable compatibility with CommonJS and ES Modules
		"skipLibCheck": true,
		// Skip type checking of declaration files
		"forceConsistentCasingInFileNames": true,
		// Ensure consistent casing in file names
		"outDir": "./dist",
		// Redirect output structure to the 'dist' directory
		"declaration": true,
		// Emit .d.ts files so consumers embedding the package get types
		"rootDir": "./src",
		// Specify the root directory of input files
		"resolveJsonModule": true,
		// Allow importing .json files
		"moduleResolution": "node",
		// Use Node.js module resolution strategy
		"allowJs": true,
		// Allow JavaScript files to be compiled
		"noImplicitAny": true
		// Raise error on expressions and declarations with an implied 'any' type
	},
	// Only compile the published source; tests under test/ run via `node --test`
	// (type-stripping) and must not be emitted into dist.
	"include": ["src"],
	"exclude": ["node_modules", "dist", "test"]
}
